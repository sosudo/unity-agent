# ─────────────────────────────────────────────────────────────────────────────
# Unity Agent configuration
#
# Quick start:
#   1.  cp .env.example .env
#   2.  Set PRIMARY_API_KEY below (only required field).
#   3.  unity --source paper.tex --project ./lean_proj
#
# Or generate interactively:  unity setup
#                             unity setup --advanced  (full questionnaire)
# ─────────────────────────────────────────────────────────────────────────────


# ── Required: API access ─────────────────────────────────────────────────────

# Your provider's API key. For direct Anthropic, set to sk-ant-...
# For an OpenAI-compatible proxy (OpenRouter, aicohort, etc.), see
# PRIMARY_BASE_URL below and the PRIMARY_AUTH_TOKEN note.
PRIMARY_API_KEY=

# Which model the agents run as. Defaults to Anthropic's most capable
# production model. For a non-Anthropic provider, use that provider's
# model identifier (e.g. "anthropic/claude-opus-4-7" on OpenRouter).
PRIMARY_MODEL=claude-opus-4-7

# Override only if using a non-Anthropic proxy or a region endpoint.
# Examples:
#   PRIMARY_BASE_URL=https://openrouter.ai/api
#   PRIMARY_BASE_URL=https://aicohort.org
# PRIMARY_BASE_URL=https://api.anthropic.com

# If your provider authenticates via Bearer rather than x-api-key
# (OpenRouter, some private routes). Most users leave this blank.
# PRIMARY_AUTH_TOKEN=


# ── Optional: secondary (escalation) tier ────────────────────────────────────
# When the critic loop detects a chunk stuck for ≥2 iterations, Unity escalates
# it to a separate model. Set these only if you want a DIFFERENT provider or
# model for escalation. If left blank, escalation reuses PRIMARY_* above.

# SECONDARY_API_KEY=
# SECONDARY_MODEL=claude-opus-4-7
# SECONDARY_BASE_URL=
# SECONDARY_AUTH_TOKEN=

# Hard ceiling on cumulative secondary-tier spend per run (USD). Escalation
# stops once cumulative secondary spend crosses this threshold.
SECONDARY_BUDGET=125


# ── Per-phase budgets (USD; blank = unlimited) ───────────────────────────────
# Per-invocation max_budget_usd passed to the agent SDK. Blank means no
# per-phase cap; SECONDARY_BUDGET above is the only hard global cap.

GENERATION_BUDGET=
SEMIFORMALIZATION_BUDGET=
EXPLORATION_BUDGET=
SOURCE_SCAN_BUDGET=
FORMALIZATION_BUDGET=
CRITIC_BUDGET=
VALIDATION_BUDGET=


# ── Pipeline flags ───────────────────────────────────────────────────────────

# Translate source → IR with autofix (recommended; required for --context).
AUTOFIX=true

# Run the exploration phase between semiformalization and formalization.
# Disable only for proof-completion runs that don't need external context.
EXPLORATION=true

# Allow exploration to spawn recursive child unity calls (depth > 0).
RECURSE=false

# Require user permission for file edits. Default: bypass (fully autonomous).
NO_BYPASS=false

# Redirect stdout/stderr to unity.out/unity.err. For unattended runs.
SILENT=false

# Tee stdout/stderr to unity.out/unity.err in addition to the terminal.
# Mutually exclusive with SILENT.
RECORDING=true

# Keep language/ (the generated IR) after the run completes.
SAVE_SPECIFICATION=true

# Keep semiformal/ (the IR-translated source) after the run completes.
SAVE_SEMIFORMALIZATION=true


# ── Iteration / retry caps (blank = no cap) ──────────────────────────────────

# Outer critic-formalization-retro loop iteration cap. Set to bound runaway
# loops on stuck proofs; 5 is a sensible starting value.
MAX_CRITIC_ITERATIONS=

# Generation ↔ validation loop iteration cap. If the validator keeps rejecting
# the IR, this bounds how many times generation retries with feedback.
MAX_VALIDATION_ITERATIONS=

# How many times the resolver may respawn on the same phase before exit(1).
# Leave blank for "unbounded" (the resolver only triggers on exceptions, so
# the practical cap is the per-phase budget); set 8 for paranoid runs.
RESOLVER_MAX_RETRIES=


# ── Server ports ─────────────────────────────────────────────────────────────

# Forum web UI port (browser view of agent posts).
FORUM_PORT=6367

# Lean LSP MCP server port (all agents connect to one shared LSP).
LEAN_LSP_PORT=6368


# ── Advanced (rarely need to change) ─────────────────────────────────────────

# Streaming idle-timeout for SDK calls (seconds). After this many seconds
# without a new message, the watchdog restarts the Lean LSP and routes
# through the resolver. Default 600s = 10min.
SDK_MESSAGE_IDLE_TIMEOUT=600

# How many idle-timeout-driven LSP restarts before Unity stops restarting and
# runs LSP-less for the remainder of the run.
MAX_LSP_RESTARTS_BEFORE_DEGRADE=2

# Per-tool-call output truncation threshold (characters). Bounds a single
# Bash/Read/Grep/Glob result's contribution to context window. ~50000
# ≈ 12.5k tokens. Blank disables truncation.
TOOL_RESULT_MAX_CHARS=50000

# SDK streaming-response close timeout (milliseconds).
CLAUDE_CODE_STREAM_CLOSE_TIMEOUT=180000

# Enable experimental Teams mode (TEAMS/ prompts instead of PROMPTS/).
# CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=false
